<script src="{{{uiRootPath}}}/js/vendor/import.js"></script>
<script src="{{{uiRootPath}}}/js/site.js"></script>
<script async src="{{{uiRootPath}}}/js/vendor/highlight.js"></script>
<script async src="{{{uiRootPath}}}/js/vendor/spring-tabs.js" data-sync-storage-key="docs:preferred-tab"></script>
<link rel="stylesheet" href="{{{siteRootPath}}}/pagefind/pagefind-component-ui.css">
<script src="{{{siteRootPath}}}/pagefind/pagefind-component-ui.js"></script>
<pagefind-config
  pagefind-path="{{{siteRootPath}}}/pagefind/"
  strings='{"placeholder":"搜索文档...","zero_results":"未找到 [SEARCH_TERM] 的相关结果","keyboard_search":"搜索","keyboard_close":"关闭","keyboard_navigate":"导航"}'
></pagefind-config>
<pagefind-modal>
  <pagefind-modal-header>
    <pagefind-input></pagefind-input>
  </pagefind-modal-header>
  <pagefind-modal-body>
    <pagefind-results></pagefind-results>
  </pagefind-modal-body>
  <pagefind-modal-footer>
    <pagefind-keyboard-hints></pagefind-keyboard-hints>
  </pagefind-modal-footer>
</pagefind-modal>
