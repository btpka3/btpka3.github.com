<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.5.14</version>
        <relativePath/>
    </parent>

    <groupId>com.github.btpka3</groupId>
    <artifactId>first-openapi1st-client-impl-native</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>first-openapi1st-client-impl-native</name>
    <description>
        Hand-written extensions on top of the generated client-api SDK:
        custom authentication (bearer/apiKey), request interceptors, client configuration builders,
        and integration tests against a mock HTTP server.
    </description>

    <properties>
        <java.version>21</java.version>
    </properties>

    <dependencies>
        <!--
            The generated JDK HttpClient client SDK.
            Provides: PetApi, StoreApi, UserApi + ApiClient + models.
        -->
        <dependency>
            <groupId>com.github.btpka3</groupId>
            <artifactId>first-openapi1st-client-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Test -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

</project>
