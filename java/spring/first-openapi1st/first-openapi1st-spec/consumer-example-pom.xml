<?xml version="1.0" encoding="UTF-8"?>
<!--
  这是后端仓库 api 模块的 pom.xml 示例片段。
  演示如何从 Maven 仓库拉取 spec artifact 并喂给 openapi-generator。
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.github.btpka3</groupId>
        <artifactId>first-openapi1st</artifactId>
        <version>0.0.1-SNAPSHOT</version>
    </parent>

    <artifactId>first-openapi1st-api</artifactId>

    <properties>
        <!--
          切换 spec 版本只需改这一行：
            开发阶段: 1.3.0-add-pet-photos-SNAPSHOT
            集成测试: 1.3.0-RC1
            正式发布: 1.3.0
        -->
        <api-spec.version>1.3.0-add-pet-photos-SNAPSHOT</api-spec.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Step 1: 从 Maven 仓库下载 spec yaml -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <executions>
                    <execution>
                        <id>download-api-spec</id>
                        <phase>initialize</phase>
                        <goals>
                            <goal>copy</goal>
                        </goals>
                        <configuration>
                            <artifactItems>
                                <artifactItem>
                                    <groupId>com.github.btpka3</groupId>
                                    <artifactId>petstore-api-spec</artifactId>
                                    <version>${api-spec.version}</version>
                                    <type>yaml</type>
                                    <classifier>openapi</classifier>
                                    <outputDirectory>${project.build.directory}/specs</outputDirectory>
                                    <destFileName>openapi-full.yaml</destFileName>
                                </artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Step 2: 从下载的 spec 生成 Java 接口 + Model -->
            <plugin>
                <groupId>org.openapitools</groupId>
                <artifactId>openapi-generator-maven-plugin</artifactId>
                <version>${openapi-generator.version}</version>
                <executions>
                    <execution>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <inputSpec>${project.build.directory}/specs/openapi-full.yaml</inputSpec>
                            <generatorName>spring</generatorName>
                            <apiPackage>com.github.btpka3.firstopenapi1st.api</apiPackage>
                            <modelPackage>com.github.btpka3.firstopenapi1st.model</modelPackage>
                            <configOptions>
                                <interfaceOnly>true</interfaceOnly>
                                <useSpringBoot3>true</useSpringBoot3>
                                <useTags>true</useTags>
                                <useResponseEntity>false</useResponseEntity>
                                <openApiNullable>false</openApiNullable>
                                <skipDefaultInterface>true</skipDefaultInterface>
                                <documentationProvider>none</documentationProvider>
                            </configOptions>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>
