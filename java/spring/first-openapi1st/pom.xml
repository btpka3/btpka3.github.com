<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.5.14</version>
        <relativePath/>
    </parent>

    <groupId>com.github.btpka3</groupId>
    <artifactId>first-openapi1st</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>first-openapi1st</name>
    <description>Demo: OpenAPI spec-first REST application</description>

    <modules>
        <module>first-openapi1st-service</module>
        <module>first-openapi1st-web</module>
    </modules>

    <properties>
        <java.version>21</java.version>
        <first-openapi1st-api.version>0.0.1-SNAPSHOT</first-openapi1st-api.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.github.btpka3</groupId>
                <artifactId>first-openapi1st-api</artifactId>
                <version>${first-openapi1st-api.version}</version>
            </dependency>
            <dependency>
                <groupId>com.github.btpka3</groupId>
                <artifactId>first-openapi1st-service</artifactId>
                <version>${project.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

</project>
